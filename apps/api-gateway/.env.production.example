# 应用配置
APP_ENV=production
DEBUG=False
SECRET_KEY=change_this_to_a_random_secret_key

# 数据库配置 (可选)
# DATABASE_URL=postgresql://user:password@localhost:5432/zhilian_os

# Redis配置 (可选)
# REDIS_URL=redis://redis:6379/0

# 企业微信配置
WECHAT_CORP_ID=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_AGENT_ID=

# 飞书配置
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# CORS配置（生产环境必须明确配置实际域名）
CORS_ORIGINS=["https://app.zhilian.com","https://dashboard.zhilian.com"]
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID","X-Store-ID","X-Brand-ID","Accept","Accept-Language"]

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/zhilian-os/app.log

# JWT配置
JWT_SECRET_KEY=change_this_to_a_random_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
