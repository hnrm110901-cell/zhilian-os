# 开机自动安装 / 自动注册模板。
# 首启服务会读取这个文件，在联网后自动执行 install_raspberry_pi_edge.sh。
EDGE_API_BASE_URL=http://127.0.0.1:8000
EDGE_API_TOKEN=replace-with-bootstrap-token
EDGE_STORE_ID=STORE001
EDGE_DEVICE_NAME=
EDGE_NETWORK_MODE=cloud
EDGE_STATUS_INTERVAL_SECONDS=30
EDGE_QUEUE_FLUSH_BATCH_SIZE=20
EDGE_SHOKZ_CALLBACK_BIND=0.0.0.0
EDGE_SHOKZ_CALLBACK_PORT=9781
EDGE_SHOKZ_CALLBACK_SECRET=replace-with-callback-secret
EDGE_STATE_DIR=/var/lib/zhilian-edge
EDGE_BOOTSTRAP_MARKER=/var/lib/zhilian-edge/.bootstrap-complete
EDGE_BOOTSTRAP_DISABLE_AFTER_SUCCESS=1
