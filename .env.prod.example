# Production env for docker-compose.prod.yml
# Usage:
#   cp .env.prod.example .env.prod
#   # fill required values
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# Required: DB/Redis credentials
POSTGRES_PASSWORD=replace_with_strong_password
REDIS_PASSWORD=replace_with_strong_password

# Required: API secrets
SECRET_KEY=replace_with_64_hex_secret
JWT_SECRET_KEY=replace_with_64_hex_secret

# Required: API database DSN (must point to postgres service in prod compose)
API_DATABASE_URL=postgresql+asyncpg://zhilian:replace_with_strong_password@postgres:5432/zhilian_os

# Optional: image/env knobs
APP_IMAGE_TAG=latest

# Optional: monitor stack
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_password
ALERTMANAGER_WEBHOOK_URL=
REDIS_EXPORTER_ADDR=redis://:replace_with_strong_password@redis:6379
POSTGRES_EXPORTER_DSN=postgresql://zhilian:replace_with_strong_password@postgres:5432/zhilian_os?sslmode=disable
OPS_REPORT_WEBHOOK_URL=
TOKEN=

# Alertmanager -> API webhook
ALERT_WEBHOOK_TOKEN=
ALERT_RECIPIENTS=ops_user_a,ops_user_b
ALERT_DEFAULT_STORE_ID=
ALERT_PERSIST_ENABLED=true
ALERT_DEDUPE_ENABLED=true
ALERT_DEDUPE_TTL_SECONDS=300
ALERT_DEDUPE_BACKEND=memory

# Optional: schedule overrides (defaults are from code)
# CELERY_WORKFORCE_HOUR=7
# CELERY_WORKFORCE_MINUTE=0
# L5_DISPATCH_HOUR=4
# L5_DISPATCH_MINUTE=30
