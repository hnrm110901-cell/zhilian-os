# ─────────────────────────────────────────────────────────────────
# Staging 环境变量模板
# 使用前：cp .env.staging.example .env.staging
# 然后填入真实密钥（.env.staging 已被 .gitignore 排除）
# ─────────────────────────────────────────────────────────────────

APP_ENV=staging
DEBUG=False

# 安全密钥 — 必填，用 openssl rand -hex 32 生成
SECRET_KEY=REPLACE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET=REPLACE_ME_generate_with_openssl_rand_hex_32

# 数据库（与 docker-compose.staging.yml 一致）
DATABASE_URL=postgresql+asyncpg://zhilian:zhilian@postgres:5432/zhilian_staging

# Redis（单节点，密码 staging）
REDIS_URL=redis://:staging@redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# CORS — staging 前端直连地址
CORS_ORIGINS=["http://localhost:3002","http://localhost:8001"]

# ── LLM（至少填一个，否则 NarrativeEngine 降级为静态模板）──────
ANTHROPIC_API_KEY=REPLACE_ME
# OPENAI_API_KEY=REPLACE_ME

# ── 企微（可选 — 未填时 push 静默 no-op）──────────────────────
# WECHAT_CORP_ID=REPLACE_ME
# WECHAT_CORP_SECRET=REPLACE_ME
# WECHAT_AGENT_ID=REPLACE_ME

# ── Celery（使用 Redis DB 1/2 与主库隔离）─────────────────────
CELERY_BROKER_URL=redis://:staging@redis:6379/1
CELERY_RESULT_BACKEND=redis://:staging@redis:6379/2
